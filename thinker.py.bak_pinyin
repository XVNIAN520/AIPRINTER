# ── 内置键盘 ──
def kb_insert(char):
    try: res.insert(tk.INSERT, char)
    except: pass

def kb_back():
    try:
        pos = res.index(tk.INSERT)
        if pos > 0: res.delete(pos - 1)
    except: pass

def kb_clear():
    try: res.delete(0, 'end')
    except: pass

def kb_left():
    try:
        pos = res.index(tk.INSERT)
        if pos > 0: res.icursor(pos - 1)
    except: pass

def kb_right():
    try:
        pos = res.index(tk.INSERT)
        if pos < len(res.get()): res.icursor(pos + 1)
    except: pass

def make_key(parent, text, cmd, w=6, c=SURFACE):
    b = tk.Label(parent, text=text, font=(FONT, 15), fg=TEXT1, bg=c,
                 width=w, height=2, cursor="hand2", relief="flat")
    b.bind("<Button-1>", lambda e, f=cmd: f())
    b.bind("<Enter>", lambda e: b.config(bg=ACCENT, fg="#fff"))
    b.bind("<Leave>", lambda e: b.config(bg=c, fg=TEXT1))
    return b

