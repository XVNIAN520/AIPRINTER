    [('Z',1),('X',1),('C',1),('V',1),('B',1),('N',1),('M',1),('，',1),('。',1)],
    [('←', 3, kb_left), ('→', 3, kb_right), ('␣', 10, lambda: kb_insert(' ')), ('删除', 5, kb_back), ('清空', 5, kb_clear)],
